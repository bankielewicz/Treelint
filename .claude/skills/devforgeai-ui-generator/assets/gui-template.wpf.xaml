<Window x:Class="YourNamespace.ComponentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Component Title"
        Height="450"
        Width="600"
        MinHeight="300"
        MinWidth="400"
        WindowStartupLocation="CenterScreen">

    <!-- Window Resources -->
    <Window.Resources>
        <!-- Styles -->
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- Converters if needed -->
        <!-- <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/> -->
    </Window.Resources>

    <!-- Main Grid -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                BorderBrush="#007ACC"
                BorderThickness="0,0,0,2"
                Padding="0,0,0,10"
                Margin="0,0,0,10">
            <TextBlock Text="Component Title"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#007ACC"/>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Example Input Group -->
                <GroupBox Header="Input Section" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Example Text Input -->
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="Example Input:"
                               Target="{Binding ElementName=ExampleTextBox}"/>
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 x:Name="ExampleTextBox"
                                 TabIndex="0"
                                 ToolTip="Enter a value"/>

                        <!-- Example Combobox -->
                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Content="Select Option:"
                               Target="{Binding ElementName=ExampleComboBox}"/>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  x:Name="ExampleComboBox"
                                  TabIndex="1"
                                  Margin="5">
                            <ComboBoxItem Content="Option 1" IsSelected="True"/>
                            <ComboBoxItem Content="Option 2"/>
                            <ComboBoxItem Content="Option 3"/>
                        </ComboBox>

                        <!-- Example Checkbox -->
                        <CheckBox Grid.Row="2"
                                  Grid.Column="1"
                                  x:Name="ExampleCheckBox"
                                  Content="Enable this option"
                                  TabIndex="2"
                                  Margin="5"/>
                    </Grid>
                </GroupBox>

                <!-- Example Data Display Group -->
                <GroupBox Header="Data Display" Margin="5">
                    <StackPanel>
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Ready"
                                   Margin="5"
                                   TextWrapping="Wrap"/>

                        <!-- Example DataGrid (commented out, uncomment if needed) -->
                        <!--
                        <DataGrid x:Name="DataGrid"
                                  AutoGenerateColumns="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  Height="150"
                                  Margin="5"/>
                        -->
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Button Panel -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="SubmitButton"
                    Content="_Submit"
                    Click="SubmitButton_Click"
                    TabIndex="3"
                    IsDefault="True"
                    Style="{StaticResource {x:Type Button}}"/>

            <Button x:Name="CancelButton"
                    Content="_Cancel"
                    Click="CancelButton_Click"
                    TabIndex="4"
                    IsCancel="True"
                    Style="{StaticResource {x:Type Button}}"/>
        </StackPanel>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
