### Phase 2: Staging Deployment

**Objective**: Deploy to staging environment and validate before production

#### Step 1: Prepare Deployment Artifacts

**Git Workflow:**

```
# Ensure on correct branch
Bash(command="git status")
current_branch = parse_current_branch(git_output)

# Create release branch from main
Bash(command="git checkout main && git pull origin main")
Bash(command=f"git checkout -b release/{story_id}")

# Generate version tag
# Version format: v{major}.{minor}.{patch} or {story-id}-release
version = generate_version_tag(story_id)  # e.g., v1.2.3 or STORY-001-release

Bash(command=f"git tag -a {version} -m 'Release {story_id}: {story.title}'")
Bash(command=f"git push origin {version}")

Report: f"✓ Git: Created release branch and tagged {version}"
```

**Build Artifacts** (language-specific):

```
# Detect project type
project_files = Glob(pattern="*.{csproj,sln,package.json,requirements.txt,pom.xml}")

IF "*.csproj" OR "*.sln":
    # .NET project
    Bash(command="dotnet restore")
    Bash(command="dotnet publish -c Release -o ./publish")
    Report: "✓ Build: .NET application published to ./publish"

ELIF "package.json":
    # Node.js project
    Bash(command="npm install")
    Bash(command="npm run build")
    Report: "✓ Build: Node.js application built"

ELIF "requirements.txt":
    # Python project
    Bash(command="pip install -r requirements.txt")
    Report: "✓ Build: Python dependencies installed"

# Build Docker image if Dockerfile exists
IF file_exists("Dockerfile"):
    image_name = get_image_name_from_config()
    registry = get_registry_from_config()

    Bash(command=f"docker build -t {image_name}:{version} .")
    Bash(command=f"docker tag {image_name}:{version} {registry}/{image_name}:{version}")
    Bash(command=f"docker push {registry}/{image_name}:{version}")

    Report: f"✓ Docker: Image pushed to {registry}/{image_name}:{version}"
```

#### Step 2: Deploy to Staging

**Deployment methods based on infrastructure:**

**Kubernetes (Helm/Kubectl):**

```
IF deployment_target == "kubernetes":
    # Update Helm values or deployment manifest
    IF helm_chart_exists:
        Bash(command=f"helm upgrade {release_name} ./chart --set image.tag={version} --namespace=staging --install")
        Bash(command=f"kubectl rollout status deployment/{deployment_name} --namespace=staging --timeout=5m")
    ELSE:
        # Use kubectl directly
        Bash(command=f"kubectl set image deployment/{deployment_name} {container_name}={image}:{version} --namespace=staging")
        Bash(command=f"kubectl rollout status deployment/{deployment_name} --namespace=staging --timeout=5m")

    Report: "✓ Kubernetes: Staging deployment complete"
```

**Azure App Service:**

```
IF deployment_target == "azure":
    # Deploy via Azure CLI
    Bash(command=f"az webapp deployment source config-zip --resource-group {rg} --name {app_name}-staging --src ./publish.zip")

    # Wait for deployment
    Bash(command=f"az webapp show --name {app_name}-staging --resource-group {rg} --query state -o tsv")

    Report: "✓ Azure: Staging deployment complete"
```

**AWS ECS:**

```
IF deployment_target == "aws_ecs":
    # Register new task definition
    Bash(command=f"aws ecs register-task-definition --cli-input-json file://task-def.json")

    # Update service
    Bash(command=f"aws ecs update-service --cluster {cluster}-staging --service {service} --task-definition {task_def}:{version}")

    # Wait for stability
    Bash(command=f"aws ecs wait services-stable --cluster {cluster}-staging --services {service}")

    Report: "✓ AWS ECS: Staging deployment complete"
```

**AWS Lambda (Serverless):**

```
IF deployment_target == "aws_lambda":
    # Deploy function
    Bash(command=f"aws lambda update-function-code --function-name {function_name}-staging --zip-file fileb://function.zip")

    # Update alias
    Bash(command=f"aws lambda update-alias --function-name {function_name} --name staging --function-version $LATEST")

    Report: "✓ AWS Lambda: Staging deployment complete"
```

**Traditional VPS (Ansible/Terraform):**

```
IF deployment_target == "vps":
    IF ansible_playbook_exists:
        Bash(command="ansible-playbook deploy-staging.yml -i inventory/staging")
    ELIF terraform_config_exists:
        Bash(command="terraform apply -target=module.staging -auto-approve")

    Report: "✓ VPS: Staging deployment complete"
```

#### Step 3: Smoke Test Staging Deployment

**Wait for application startup:**

```
# Allow time for application to initialize
Report: "Waiting 30 seconds for application startup..."
sleep(30)
```

**Health Endpoint Check:**

```
# Get staging URL from configuration
staging_url = get_staging_url_from_config()

# Execute health check script
TRY:
    Bash(command=f"python {SKILL_DIR}/scripts/health_check.py --url {staging_url}/health --retries 5 --timeout 10")
    health_check_passed = True
EXCEPT:
    health_check_passed = False
    health_error = parse_health_check_error()

IF NOT health_check_passed:
    CRITICAL: "Staging health check failed"
    Report: f"Health endpoint {staging_url}/health not responding"
    Detail: health_error
    Action: "Rollback staging deployment"

    # Rollback staging (revert to previous version)
    execute_staging_rollback(deployment_target, previous_version)

    BLOCK: "Cannot proceed to production - staging deployment failed health check"
    Return: BLOCKED
```

**Functional Smoke Tests:**

```
# Load smoke testing guide
Read(file_path=".claude/skills/devforgeai-release/references/smoke-testing-guide.md")

# Run automated smoke tests
smoke_test_suite = [
    "test_user_authentication",
    "test_api_endpoints_respond",
    "test_database_connectivity",
    "test_external_integrations"
]

Report: "Running smoke tests against staging environment..."

FOR each test in smoke_test_suite:
    TRY:
        Bash(command=f"pytest tests/smoke/{test}.py --environment=staging --verbose")
        test_results[test] = "PASS"
    EXCEPT:
        test_results[test] = "FAIL"
        failed_tests.append(test)

IF failed_tests.exists:
    CRITICAL: "Staging smoke tests failed"
    Report: f"Failed tests: {', '.join(failed_tests)}"

    # Show detailed test output
    FOR each failed_test in failed_tests:
        Report: f"\n{failed_test} Output:"
        Read(file_path=f"test-results/{failed_test}.log")

    Action: "Rollback staging deployment"
    execute_staging_rollback(deployment_target, previous_version)

    BLOCK: "Cannot proceed to production - staging smoke tests failed"
    Return: BLOCKED

Report: "✓ Smoke Tests: All tests passed in staging"
```

**Manual Validation (Optional):**

```
AskUserQuestion:
Question: "Staging deployment complete. Smoke tests passed. Perform manual validation before production?"
Header: "Manual testing"
Description: f"Staging URL: {staging_url}"
Options:
  - label: "Manual testing complete - Proceed to production"
    description: "Manual validation successful, ready for production deployment"
  - label: "Issues found - Rollback staging"
    description: "Discovered issues during manual testing"
  - label: "Skip manual testing - Proceed to production"
    description: "Trust automated tests, deploy to production immediately"
multiSelect: false

IF answer == "Issues found":
    Report: "Manual validation failed - rolling back staging"
    execute_staging_rollback(deployment_target, previous_version)
    BLOCK: "Manual validation failed"
    Return: BLOCKED

IF answer == "Manual testing complete" OR answer == "Skip manual testing":
    Report: "✓ Staging Validation: Complete and successful"
    # Proceed to production deployment
```

---

### Phase 3: Production Deployment

**Objective**: Deploy to production using selected strategy

#### Step 1: Final Pre-Production Checks

**Production Readiness Confirmation:**

```
AskUserQuestion:
Question: f"Ready to deploy {story_id} to PRODUCTION using {deployment_strategy} strategy?"
Header: "Production deployment"
Description: f"This will deploy version {version} to production environment"
Options:
  - label: "Yes - Proceed with production deployment"
    description: "Staging validated, ready for production"
  - label: "No - Abort deployment (need more testing)"
    description: "Keep staging deployed for additional testing"
  - label: "Wait - Not ready yet (maintenance window pending)"
    description: "Staging ready, wait for approved deployment window"
multiSelect: false

IF answer == "No":
    Report: "Production deployment aborted by user"
    Action: "Staging remains deployed for testing"
    Return: ABORTED

IF answer == "Wait":
    Report: "Production deployment postponed"
    Action: "Staging deployed and validated, awaiting deployment window"
    Return: POSTPONED
```

**Backup Current Production State:**

```
# Capture current production version for rollback
current_production_version = get_current_production_version(deployment_target)

Report: f"Current production version: {current_production_version}"
Report: "Creating rollback checkpoint..."

# Database backup if needed
IF requires_database_migration(story_id):
    AskUserQuestion:
    Question: "This deployment includes database migrations. Create database backup?"
    Header: "Database backup"
    Description: "Backup allows safe rollback if issues occur"
    Options:
      - label: "Yes - Create backup (recommended)"
        description: "Safe: allows full rollback including database"
      - label: "No - Skip backup (forward-only migration)"
        description: "RISKY: Cannot rollback database changes"
    multiSelect: false

    IF answer == "Yes":
        TRY:
            Bash(command="./scripts/backup_database.sh production")
            backup_id = parse_backup_id(backup_output)
            Report: f"✓ Database backup created: {backup_id}"
        EXCEPT:
            CRITICAL: "Database backup failed"
            BLOCK: "Cannot proceed without backup"
            Return: BLOCKED
```

#### Step 2: Execute Deployment Strategy

**Blue-Green Deployment:**

```
IF deployment_strategy == "Blue-Green":
    Report: "Executing Blue-Green deployment strategy..."

    # Step 1: Deploy to green environment (inactive)
    Bash(command=f"helm upgrade {release_name}-green ./chart --set image.tag={version} --namespace=production-green --install")
    Bash(command=f"kubectl rollout status deployment/{deployment_name} --namespace=production-green --timeout=5m")

    Report: "✓ Green environment deployed"

    # Step 2: Run smoke tests against green
    Report: "Running smoke tests against green environment..."

    green_url = get_green_environment_url()

    TRY:
        Bash(command=f"python {SKILL_DIR}/scripts/smoke_test_runner.py --environment production-green --url {green_url}")
        smoke_tests_passed = True
    EXCEPT:
        smoke_tests_passed = False

    IF NOT smoke_tests_passed:
        CRITICAL: "Smoke tests failed in production-green environment"
        Report: "Rolling back: Deleting green deployment"
        Bash(command=f"helm uninstall {release_name}-green --namespace=production-green")
        BLOCK: "Blue-Green deployment failed smoke tests"
        Return: BLOCKED

    # Step 3: Switch traffic from blue to green
    Report: "Switching traffic from blue to green..."
    Bash(command=f"kubectl patch service/{service_name} -n production -p '{{\"spec\":{{\"selector\":{{\"version\":\"green\"}}}}}}'")

    Report: "✓ Traffic switched to green environment"

    # Step 4: Monitor production metrics for 5 minutes
    Report: "Monitoring production metrics (5 minutes)..."

    TRY:
        Bash(command=f"python {SKILL_DIR}/scripts/metrics_collector.py --environment production --duration 300 --baseline-compare")
        metrics_healthy = parse_metrics_result(metrics_output)
    EXCEPT:
        metrics_healthy = False

    IF NOT metrics_healthy:
        CRITICAL: "Production metrics degraded after switching to green"
        Report: "Rolling back: Switching traffic back to blue"
        Bash(command=f"kubectl patch service/{service_name} -n production -p '{{\"spec\":{{\"selector\":{{\"version\":\"blue\"}}}}}}'")
        BLOCK: "Blue-Green deployment failed metrics validation"
        Return: BLOCKED

    Report: "✓ Blue-Green deployment successful"
    Report: "Blue environment kept as rollback option (will be scaled down after monitoring period)"
```

**Rolling Update Deployment:**

```
IF deployment_strategy == "Rolling Update":
    Report: "Executing Rolling Update deployment strategy..."

    # Update deployment with rolling update strategy
    Bash(command=f"kubectl set image deployment/{deployment_name} {container}={image}:{version} --namespace=production")

    # Monitor rollout progress
    Report: "Monitoring rolling update progress..."
    Bash(command=f"kubectl rollout status deployment/{deployment_name} --namespace=production --timeout=10m")

    # Kubernetes automatically:
    # - Updates 25% of pods at a time (default maxSurge/maxUnavailable)
    # - Monitors health checks
    # - Pauses if failures detected

    rollout_status = parse_kubectl_output(rollout_output)

    IF rollout_status == "success":
        Report: "✓ Rolling update completed successfully"
    ELSE:
        CRITICAL: "Rolling update failed"
        Report: "Rolling back to previous version"
        Bash(command=f"kubectl rollout undo deployment/{deployment_name} --namespace=production")
        BLOCK: "Rolling update failed"
        Return: BLOCKED
```

**Canary Deployment:**

```
IF deployment_strategy == "Canary":
    Report: "Executing Canary deployment strategy..."

    # Step 1: Deploy canary version (5% traffic)
    Report: "Deploying canary (5% traffic)..."
    Bash(command=f"helm upgrade {release_name}-canary ./chart --set image.tag={version} --set replicaCount=1 --namespace=production --install")

    # Configure traffic split (95% baseline, 5% canary)
    Bash(command="kubectl apply -f canary-traffic-split-5.yaml")

    # Step 2: Monitor canary metrics for 10 minutes
    Report: "Monitoring canary metrics (10 minutes, 5% traffic)..."
    canary_metrics_5 = monitor_canary_metrics(duration=600, canary_percentage=5)

    IF canary_metrics_5.error_rate > baseline_error_rate * 1.1:
        CRITICAL: "Canary error rate too high at 5%"
        Report: f"Canary error rate: {canary_metrics_5.error_rate}, Baseline: {baseline_error_rate}"
        execute_canary_rollback()
        BLOCK: "Canary deployment failed at 5%"
        Return: BLOCKED

    # Step 3: Increase to 25% traffic
    Report: "Canary healthy at 5%, increasing to 25% traffic..."
    Bash(command="kubectl apply -f canary-traffic-split-25.yaml")

    canary_metrics_25 = monitor_canary_metrics(duration=600, canary_percentage=25)

    IF NOT canary_metrics_25.healthy:
        CRITICAL: "Canary metrics degraded at 25%"
        execute_canary_rollback()
        BLOCK: "Canary deployment failed at 25%"
        Return: BLOCKED

    # Step 4: Increase to 50% traffic
    Report: "Canary healthy at 25%, increasing to 50% traffic..."
    Bash(command="kubectl apply -f canary-traffic-split-50.yaml")

    canary_metrics_50 = monitor_canary_metrics(duration=600, canary_percentage=50)

    IF NOT canary_metrics_50.healthy:
        CRITICAL: "Canary metrics degraded at 50%"
        execute_canary_rollback()
        BLOCK: "Canary deployment failed at 50%"
        Return: BLOCKED

    # Step 5: Complete rollout to 100%
    Report: "Canary healthy at 50%, completing rollout to 100%..."
    Bash(command=f"kubectl scale deployment/{deployment_name} --replicas=0 --namespace=production")  # Scale down baseline
    Bash(command=f"kubectl scale deployment/{deployment_name}-canary --replicas={target_replicas} --namespace=production")

    Report: "✓ Canary rollout successful - 100% traffic on new version"
```

**Recreate Deployment:**

```
IF deployment_strategy == "Recreate":
    Report: "Executing Recreate deployment strategy..."
    WARN: "This strategy will cause brief downtime during deployment"

    # Step 1: Scale down current version
    Report: "Scaling down current version..."
    Bash(command=f"kubectl scale deployment/{deployment_name} --replicas=0 --namespace=production")

    # Wait for pods to terminate
    sleep(30)

    # Step 2: Deploy new version
    Report: "Deploying new version..."
    Bash(command=f"kubectl set image deployment/{deployment_name} {container}={image}:{version} --namespace=production")
    Bash(command=f"kubectl scale deployment/{deployment_name} --replicas={target_replicas} --namespace=production")

    # Step 3: Wait for new pods to be ready
    Bash(command=f"kubectl rollout status deployment/{deployment_name} --namespace=production --timeout=5m")

    rollout_status = parse_kubectl_output(rollout_output)

    IF rollout_status == "success":
        Report: "✓ Recreate deployment successful"
    ELSE:
        CRITICAL: "Recreate deployment failed"
        Report: "Rolling back to previous version"
        Bash(command=f"kubectl set image deployment/{deployment_name} {container}={image}:{current_production_version} --namespace=production")
        Bash(command=f"kubectl scale deployment/{deployment_name} --replicas={target_replicas}")
        BLOCK: "Recreate deployment failed"
        Return: BLOCKED
```

---

### Phase 4: Post-Deployment Validation

**Objective**: Verify production deployment health and stability

#### Step 1: Production Smoke Tests

```
# Wait for application to stabilize
Report: "Waiting 60 seconds for production application to stabilize..."
sleep(60)

# Get production URL
production_url = get_production_url_from_config()

# Health check
Report: "Running production health check..."
TRY:
    Bash(command=f"python {SKILL_DIR}/scripts/health_check.py --url {production_url}/health --retries 5")
    health_check_passed = True
EXCEPT:
    health_check_passed = False

IF NOT health_check_passed:
    CRITICAL: "Production health check failed"
    Report: "Initiating emergency rollback..."
    execute_production_rollback(deployment_target, deployment_strategy, current_production_version)
    BLOCK: "Production deployment failed health check"
    Return: BLOCKED

# Run smoke tests
Report: "Running smoke tests against production..."
TRY:
    Bash(command=f"python {SKILL_DIR}/scripts/smoke_test_runner.py --environment production --url {production_url}")
    smoke_tests_passed = True
EXCEPT:
    smoke_tests_passed = False
    failed_tests = parse_failed_tests()

IF NOT smoke_tests_passed:
    CRITICAL: "Production smoke tests failed"
    Report: f"Failed tests: {', '.join(failed_tests)}"
    Report: "Initiating emergency rollback..."
    execute_production_rollback(deployment_target, deployment_strategy, current_production_version)
    BLOCK: "Production deployment failed smoke tests"
    Return: BLOCKED

Report: "✓ Production smoke tests: All passed"
```

#### Step 2: Metrics Monitoring

```
# Monitor key production metrics for 15 minutes
Report: "Monitoring production metrics (15 minutes)..."

TRY:
    Bash(command=f"python {SKILL_DIR}/scripts/metrics_collector.py --environment production --duration 900 --metrics error_rate,response_time_p95,cpu,memory --baseline-compare")
    metrics_report = parse_metrics_output()
EXCEPT:
    WARN: "Metrics collection failed - manual monitoring required"
    metrics_report = None

IF metrics_report:
    # Compare against baseline
    baseline = load_baseline_metrics()

    CHECKS:
      ✓ error_rate < baseline_error_rate * 1.2  # Within 20% of baseline
      ✓ response_time_p95 < baseline_p95 * 1.3  # Within 30% of baseline
      ✓ cpu_utilization < 80%  # Not overloaded
      ✓ memory_usage < 85%  # Not memory-starved

    violations = []

    IF metrics_report.error_rate > baseline.error_rate * 1.2:
        violations.append(f"Error rate increased: {metrics_report.error_rate} vs baseline {baseline.error_rate}")

    IF metrics_report.response_time_p95 > baseline.p95 * 1.3:
        violations.append(f"Response time degraded: {metrics_report.response_time_p95}ms vs baseline {baseline.p95}ms")

    IF metrics_report.cpu > 80:
        violations.append(f"CPU utilization high: {metrics_report.cpu}%")

    IF metrics_report.memory > 85:
        violations.append(f"Memory usage high: {metrics_report.memory}%")

    IF violations.exists:
        WARN: "Production metrics show degradation"
        Report: f"Metrics violations:\n" + "\n".join(violations)

        AskUserQuestion:
        Question: "Production metrics show degradation. How to proceed?"
        Header: "Metrics warning"
        Description: "Deployment successful but metrics outside normal thresholds"
        Options:
          - label: "Continue monitoring - Acceptable degradation"
            description: "Metrics within acceptable range, continue monitoring"
          - label: "Rollback immediately - Unacceptable performance"
            description: "Performance degradation too severe"
          - label: "Investigate before deciding - Gather more data"
            description: "Monitor for additional 15 minutes before decision"
        multiSelect: false

        IF answer == "Rollback immediately":
            Report: "User requested rollback due to metrics degradation"
            execute_production_rollback(deployment_target, deployment_strategy, current_production_version)
            BLOCK: "Production deployment rolled back due to metrics"
            Return: ROLLED_BACK

        IF answer == "Investigate before deciding":
            Report: "Extended monitoring period (15 minutes)..."
            # Monitor for additional period
            extended_metrics = monitor_extended(duration=900)
            # Re-evaluate based on extended metrics

    ELSE:
        Report: "✓ Production metrics: Within acceptable thresholds"
```

#### Step 3: User Acceptance Validation (Optional)

```
# For high-risk deployments, allow manual UAT
AskUserQuestion:
Question: "Production deployment complete. Smoke tests and metrics passed. Perform user acceptance testing?"
Header: "User acceptance testing"
Description: "Final validation with real users before declaring release successful"
Options:
  - label: "UAT complete - Release successful"
    description: "Manual validation successful, declare release complete"
  - label: "Issues found - Rollback"
    description: "Discovered issues during UAT"
  - label: "Skip UAT - Declare success"
    description: "Trust automated validation, declare release successful"
multiSelect: false

IF answer == "Issues found":
    Report: "UAT failed - initiating rollback"
    execute_production_rollback(deployment_target, deployment_strategy, current_production_version)
    BLOCK: "Production deployment rolled back due to UAT failures"
    Return: ROLLED_BACK

IF answer == "UAT complete" OR answer == "Skip UAT":
    Report: "✓ Production validation: Complete and successful"
```

