{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Question Selection Context",
  "description": "Schema for context object passed to AdaptiveQuestioningEngine.select_questions()",
  "type": "object",
  "required": ["operation_type", "success_status"],
  "properties": {
    "operation_type": {
      "type": "string",
      "enum": ["dev", "qa", "release", "orchestrate", "ideate"],
      "description": "Type of operation that completed"
    },
    "success_status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "blocked"],
      "description": "Outcome status of the operation"
    },
    "user_id": {
      "type": "string",
      "description": "Optional user identifier for history filtering"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of operation completion"
    },
    "operation_history": {
      "type": "array",
      "description": "Previous operations for this user",
      "items": {
        "type": "object",
        "properties": {
          "operation_id": { "type": "string" },
          "operation_type": { "type": "string" },
          "success_status": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "user_id": { "type": "string" }
        }
      }
    },
    "question_history": {
      "type": "array",
      "description": "Previously answered questions",
      "items": {
        "type": "object",
        "properties": {
          "question_id": { "type": "string" },
          "answered_at": { "type": "string", "format": "date-time" },
          "response": { "type": "string" }
        }
      }
    },
    "error_logs": {
      "type": "array",
      "description": "Error messages if operation failed",
      "items": { "type": "string" }
    },
    "performance_metrics": {
      "type": "object",
      "properties": {
        "execution_time_ms": { "type": "number" },
        "token_usage": { "type": "number" },
        "complexity_score": { "type": "number" }
      }
    }
  }
}
