# DevForgeAI Hook Configuration Example
#
# This file shows example hook configurations for all DevForgeAI operations.
# Copy sections to hooks.yaml and customize as needed.

# ============================================================================
# POST-ORCHESTRATE WORKFLOW RETROSPECTIVE (STORY-026)
# ============================================================================

# Triggers after complete /orchestrate workflow execution (dev → qa → release)
# Use for capturing end-to-end workflow insights and bottleneck analysis

- id: post-orchestrate-retrospective
  name: "Post-Orchestrate Workflow Retrospective"
  operation_type: command
  operation_pattern: "orchestrate"

  # CONFIGURATION OPTION 1: Failures-Only Mode (DEFAULT - AC4)
  # Only triggers when workflow fails (any phase: dev, QA, or release)
  trigger_status: [failure]

  # CONFIGURATION OPTION 2: All-Statuses Mode
  # Triggers on both success and failure for comprehensive feedback
  # trigger_status: [success, failure]

  trigger_conditions:
    # No user approval required (automatic trigger)
    user_approval_required: false

    # No minimum duration (all workflows eligible)
    operation_duration_min_ms: 0

    # OPTIONAL: Only trigger for specific story complexities
    # story_points_min: 5  # Only stories ≥5 points

  feedback_type: conversation
  feedback_config:
    mode: "comprehensive"  # Full retrospective for end-to-end workflows

    # Workflow-level questions (AC5: focus on phases, gates, duration)
    questions:
      # Bottleneck identification
      - "Which phase was the biggest bottleneck (dev, QA, or release)?"

      # Quality gate effectiveness
      - "Did quality gates catch issues effectively (coverage, compliance, deployment)?"

      # Failure analysis
      - "Were there unexpected failures or blockers during the workflow?"

      # Process improvement
      - "How could the end-to-end workflow be improved?"

      # Checkpoint-specific (AC3: if checkpoint resume detected)
      - "If you resumed from a checkpoint, was the context clear about what needed to be done?"

      # Performance reflection
      - "Was the total workflow duration acceptable for this story complexity?"

    # OPTIONAL: Custom questions for specific scenarios
    # checkpoint_resume_questions:
    #   - "Did the checkpoint resume preserve all necessary context?"
    # qa_retry_questions:
    #   - "After QA retries, were the failure reasons clear?"

  # Performance targets (AC7)
  max_duration_ms: 5000  # Feedback session initialization timeout

  # Enable/disable hook
  enabled: false  # DISABLED until Phase N wiring complete in /orchestrate.md

  # Metadata for tracking and debugging
  tags: [orchestrate, workflow, end-to-end, retrospective, story-026]
  metadata:
    story_id: "STORY-026"
    acceptance_criteria: ["AC1", "AC2", "AC3", "AC4", "AC5", "AC6", "AC7"]
    implementation_date: "2025-11-14"
    notes: |
      - Failures-only mode is the default (AC4)
      - Change trigger_status to [success, failure] for all-statuses mode
      - Hook invokes after ALL phases complete (dev, QA, release)
      - Supports checkpoint resume scenarios (AC3)
      - Graceful degradation on hook failures (AC6)
      - Performance: check <100ms, invoke <3s, overhead <200ms (AC7)

# ============================================================================
# POST-EPIC-CREATE FEEDBACK (STORY-028)
# ============================================================================

# Triggers after successful epic creation with feature decomposition complete
# Use for capturing epic quality, feature granularity, and complexity assessment feedback

- id: post-epic-create-feedback
  name: "Post-Epic Creation Feedback"
  operation_type: command
  operation_pattern: "create-epic"

  # Trigger on successful epic creation only
  trigger_status: [success]

  trigger_conditions:
    # No user approval required (automatic trigger)
    user_approval_required: false

    # No minimum duration (all epic creations eligible)
    operation_duration_min_ms: 0

    # OPTIONAL: Only trigger for epics with specific complexity scores
    # complexity_score_min: 6  # Only epics rated ≥6 complexity

  feedback_type: conversation
  feedback_config:
    mode: "focused"  # Targeted questions for epic creation quality

    # Epic-specific questions (AC4: goal clarity, scope, success metrics)
    questions:
      # Feature decomposition quality
      - "You created {feature_count} features for this epic. Was this the right granularity (3-8 recommended)?"

      # Complexity assessment confidence
      - "The complexity score was {complexity_score}/10. How confident are you in this assessment?"

      # Goal clarity
      - "Was the epic goal statement clear and measurable?"

      # Risk identification
      - "Were the identified risks comprehensive? Any missing risks?"

      # Success criteria
      - "Are the success criteria measurable and achievable?"

      # Technical feasibility
      - "Do you foresee any technical challenges not captured in the assessment?"

  # Performance targets (AC: hook check <100ms, invoke <500ms)
  max_duration_ms: 30000  # 30 second timeout for feedback conversation

  # Enable/disable hook
  enabled: false  # DISABLED by default - enable when ready to collect epic feedback

  # Metadata for tracking and debugging
  tags: [create-epic, epic-creation, planning, retrospective, story-028]
  metadata:
    story_id: "STORY-028"
    acceptance_criteria: ["AC1", "AC2", "AC3", "AC4", "AC5"]
    implementation_date: "2025-11-16"
    notes: |
      - Triggers after Phase 4A.9 in devforgeai-orchestration skill
      - Epic context automatically extracted (epic-id, features, complexity, risks)
      - Questions reference actual epic data ({feature_count}, {complexity_score})
      - Hook failure is non-blocking (epic creation always exits 0)
      - Performance: check <100ms, invoke <500ms, overhead <3s

# ============================================================================
# POST-SPRINT-CREATE FEEDBACK (STORY-029)
# ============================================================================

# Triggers after successful sprint creation with story selection complete
# Use for capturing sprint planning insights, story selection rationale, and capacity feedback

- id: post-sprint-create-feedback
  name: "Post-Sprint Creation Feedback"
  operation_type: command
  operation_pattern: "create-sprint"

  # Trigger on successful sprint creation only
  trigger_status: [success]

  trigger_conditions:
    # No user approval required (automatic trigger)
    user_approval_required: false

    # No minimum duration (all sprint creations eligible)
    operation_duration_min_ms: 0

    # OPTIONAL: Only trigger for sprints with specific story counts
    # story_count_min: 3  # Only sprints with ≥3 stories

  feedback_type: conversation
  feedback_config:
    mode: "focused"  # Targeted questions for sprint planning quality

    # Sprint-specific questions (AC3: sprint context available)
    questions:
      # Story selection rationale
      - "You selected {story_count} stories ({capacity_points} points total). How did you decide on this selection?"

      # Capacity appropriateness
      - "Is {capacity_points} points appropriate for your team's velocity (20-40 recommended)?"

      # Sprint goal clarity
      - "Is the sprint goal clear and achievable with these {story_count} stories?"

      # Story dependencies
      - "Are there any dependencies between the selected stories that could cause sequencing issues?"

      # Risk awareness
      - "What are the biggest risks to completing this sprint successfully?"

      # Empty sprint handling (AC5: adapt to zero stories)
      - "Why create a sprint without stories? (Planning ahead, capacity constraints, etc.)"

  # Performance targets (NFR-001, NFR-002, NFR-003)
  max_duration_ms: 30000  # 30 second timeout for feedback conversation

  # Enable/disable hook
  enabled: false  # DISABLED by default - enable when ready to collect sprint feedback

  # Metadata for tracking and debugging
  tags: [create-sprint, sprint-planning, capacity-planning, retrospective, story-029]
  metadata:
    story_id: "STORY-029"
    acceptance_criteria: ["AC1", "AC2", "AC3", "AC4", "AC5"]
    implementation_date: "2025-11-16"
    notes: |
      - Triggers after Phase N in /create-sprint command
      - Sprint context automatically extracted (sprint-name, story-count, capacity)
      - Questions reference actual sprint data ({story_count}, {capacity_points})
      - Hook failure is non-blocking (sprint creation always exits 0)
      - Performance: check <100ms, invoke <3s, overhead <3.5s
      - Empty sprint support: --story-count=0 --capacity=0 (AC5)

